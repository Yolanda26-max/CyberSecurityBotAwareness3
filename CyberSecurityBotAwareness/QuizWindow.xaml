<Window x:Class="CyberSecurityBotAwareness.QuizWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="🎮 Cybersecurity Quiz" Height="600" Width="700"
        Background="#1A1A2E" WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">

    <Grid Margin="25">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <Border Grid.Row="0" Background="#16213E" CornerRadius="10" Padding="18,12" Margin="0,0,0,15">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Text="🎮  Cybersecurity Quiz"
                               FontFamily="Segoe UI" FontSize="18" FontWeight="Bold"
                               Foreground="#E91E8C"/>
                    <TextBlock Text="Test your cybersecurity knowledge!"
                               FontFamily="Segoe UI" FontSize="11" Foreground="#8B8BA7"
                               Margin="0,4,0,0"/>
                </StackPanel>
                <StackPanel Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Right">
                    <TextBlock x:Name="ScoreLabel"
                               Text="Score: 0 / 0"
                               FontFamily="Segoe UI" FontSize="14" FontWeight="Bold"
                               Foreground="#E91E8C" HorizontalAlignment="Right"/>
                    <TextBlock x:Name="QuestionCountLabel"
                               Text="Question 1 of 12"
                               FontFamily="Segoe UI" FontSize="11"
                               Foreground="#8B8BA7" HorizontalAlignment="Right"
                               Margin="0,4,0,0"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- PROGRESS BAR -->
        <ProgressBar x:Name="QuizProgress"
                     Grid.Row="1" Height="6"
                     Minimum="0" Maximum="12" Value="0"
                     Background="#0F3460" Foreground="#E91E8C"
                     BorderThickness="0" Margin="0,0,0,15"/>

        <!-- QUESTION AREA -->
        <Border Grid.Row="2" Background="#16213E" CornerRadius="10" Padding="25">
            <StackPanel>

                <!-- Question type badge -->
                <Border x:Name="QuestionTypeBadge"
                        Background="#7B2D8B" CornerRadius="4"
                        Padding="8,3" HorizontalAlignment="Left" Margin="0,0,0,12">
                    <TextBlock x:Name="QuestionTypeLabel"
                               Text="MULTIPLE CHOICE"
                               FontFamily="Segoe UI" FontSize="10"
                               FontWeight="Bold" Foreground="#FFFFFF"/>
                </Border>

                <!-- Question text -->
                <TextBlock x:Name="QuestionText"
                           Text="Loading question..."
                           FontFamily="Segoe UI" FontSize="15"
                           FontWeight="SemiBold" Foreground="#FFFFFF"
                           TextWrapping="Wrap" Margin="0,0,0,20"
                           LineHeight="22"/>

                <!-- Answer options -->
                <RadioButton x:Name="OptionA" GroupName="Answers"
                             Foreground="#C9D1D9" FontFamily="Segoe UI"
                             FontSize="13" Margin="0,0,0,10" Cursor="Hand"/>
                <RadioButton x:Name="OptionB" GroupName="Answers"
                             Foreground="#C9D1D9" FontFamily="Segoe UI"
                             FontSize="13" Margin="0,0,0,10" Cursor="Hand"/>
                <RadioButton x:Name="OptionC" GroupName="Answers"
                             Foreground="#C9D1D9" FontFamily="Segoe UI"
                             FontSize="13" Margin="0,0,0,10" Cursor="Hand"/>
                <RadioButton x:Name="OptionD" GroupName="Answers"
                             Foreground="#C9D1D9" FontFamily="Segoe UI"
                             FontSize="13" Margin="0,0,0,10" Cursor="Hand"/>

                <!-- Feedback -->
                <Border x:Name="FeedbackBorder"
                        Background="#0F3460" CornerRadius="8"
                        Padding="15" Margin="0,15,0,0"
                        Visibility="Collapsed">
                    <TextBlock x:Name="FeedbackText"
                               FontFamily="Segoe UI" FontSize="13"
                               Foreground="#FFFFFF" TextWrapping="Wrap"/>
                </Border>
            </StackPanel>
        </Border>

        <!-- SUBMIT BUTTON -->
        <Border Grid.Row="3" Margin="0,15,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="QuizStatus" Grid.Column="0"
                           Text="" Foreground="#8B8BA7"
                           FontFamily="Segoe UI" FontSize="11"
                           VerticalAlignment="Center"/>
                <Button x:Name="SubmitNextButton" Grid.Column="1"
                        Content="Submit Answer"
                        Background="#E91E8C" Foreground="White"
                        FontFamily="Segoe UI" FontWeight="SemiBold"
                        FontSize="13" Padding="24,10"
                        BorderThickness="0" Cursor="Hand"
                        Click="SubmitNextButton_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}"
                                    CornerRadius="8" Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>
        </Border>

        <!-- RESULT PANEL -->
        <Border x:Name="ResultPanel" Grid.Row="4"
                Background="#16213E" CornerRadius="10"
                Padding="18" Margin="0,15,0,0"
                Visibility="Collapsed">
            <StackPanel>
                <TextBlock x:Name="ResultText"
                           FontFamily="Segoe UI" FontSize="15"
                           FontWeight="Bold" Foreground="#E91E8C"
                           HorizontalAlignment="Center"/>
                <Button Content="🔄  Play Again"
                        Background="#7B2D8B" Foreground="White"
                        FontFamily="Segoe UI" FontWeight="SemiBold"
                        FontSize="12" Padding="20,8"
                        BorderThickness="0" Cursor="Hand"
                        HorizontalAlignment="Center" Margin="0,12,0,0"
                        Click="PlayAgainButton_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}"
                                    CornerRadius="6" Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </StackPanel>
        </Border>
    </Grid>
</Window>