<Window x:Class="CyberSecurityBotAwareness.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Cybersecurity Guardian Bot" Height="700" Width="900"
        Background="#1A1A2E" WindowStartupLocation="CenterScreen">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <Border Grid.Row="0" Background="#16213E" Padding="20,15">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Logo circle -->
                <Border Grid.Column="0" Width="45" Height="45"
                        CornerRadius="25" Background="#E91E8C"
                        VerticalAlignment="Center" Margin="0,0,15,0">
                    <TextBlock Text="🛡" FontSize="22"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
                </Border>

                <!-- Title -->
                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <TextBlock Text="Cybersecurity Guardian"
                               FontFamily="Segoe UI" FontSize="20"
                               FontWeight="Bold" Foreground="#FFFFFF"/>
                    <TextBlock Text="Your personal online safety assistant"
                               FontFamily="Segoe UI" FontSize="11"
                               Foreground="#E91E8C"/>
                </StackPanel>

                <!-- Status dot -->
                <StackPanel Grid.Column="2" Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <Ellipse Width="10" Height="10" Fill="#E91E8C"
                             VerticalAlignment="Center" Margin="0,0,6,0"/>
                    <TextBlock Text="Online" Foreground="#FFFFFF"
                               FontFamily="Segoe UI" FontSize="12"
                               VerticalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- CHAT AREA -->
        <Border Grid.Row="1" Background="#1A1A2E" Margin="15,10,15,10">
            <ScrollViewer x:Name="ChatScrollViewer"
                          VerticalScrollBarVisibility="Auto">
                <RichTextBox x:Name="ChatDisplay"
                             Background="Transparent"
                             BorderThickness="0"
                             IsReadOnly="True"
                             FontFamily="Segoe UI"
                             FontSize="13"
                             Foreground="#FFFFFF"
                             Padding="10"
                             VerticalScrollBarVisibility="Disabled"/>
            </ScrollViewer>
        </Border>

        <!-- INPUT AREA -->
        <Border Grid.Row="2" Background="#16213E"
                Margin="15,0,15,10" CornerRadius="12" Padding="12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Background="#0F3460"
                        CornerRadius="8" Padding="2">
                    <TextBox x:Name="UserInputBox"
                             Background="Transparent"
                             Foreground="#FFFFFF"
                             BorderThickness="0"
                             FontFamily="Segoe UI"
                             FontSize="13"
                             Padding="10,8"
                             CaretBrush="#E91E8C"
                             VerticalContentAlignment="Center"
                             KeyDown="UserInputBox_KeyDown"/>
                </Border>

                <Button x:Name="SendButton"
                        Grid.Column="1"
                        Content="Send" Margin="10,0,0,0"
                        Background="#E91E8C" Foreground="White"
                        FontFamily="Segoe UI" FontWeight="SemiBold"
                        FontSize="13" Padding="20,10"
                        BorderThickness="0" Cursor="Hand">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}"
                                    CornerRadius="8" Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <Button x:Name="ClearButton"
                        Grid.Column="2"
                        Content="Clear" Margin="8,0,0,0"
                        Background="#0F3460" Foreground="#E91E8C"
                        FontFamily="Segoe UI" FontWeight="SemiBold"
                        FontSize="13" Padding="20,10"
                        BorderThickness="0" Cursor="Hand">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}"
                                    CornerRadius="8" Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>
        </Border>

        <!-- STATUS BAR -->
        <Border Grid.Row="3" Background="#16213E" Padding="20,8">
            <TextBlock x:Name="StatusBar"
                       Text="● Ready to assist you"
                       FontFamily="Segoe UI" FontSize="11"
                       Foreground="#E91E8C"/>
        </Border>
    </Grid>
</Window>